# ==============================================================================
# LangGuard Core - Example Environment Configuration
# ==============================================================================

# --- LLM Provider (Groq) ---
# Get your key at: https://console.groq.com/
GROQ_API_KEY="your_groq_api_key_here"

# --- Search Tool (Tavily) ---
# Get your key at: https://tavily.com/
TAVILY_API_KEY="your_tavily_api_key_here"

# --- Remote Vector Database (ChromaDB Cloud) ---
# Ensure you use the exact tenant and database names from your Chroma Cloud console
CHROMA_API_KEY="your_chroma_cloud_api_key"
CHROMA_TENANT="your_chroma_tenant_id"
CHROMA_DATABASE="your_database_name"

# --- Graph Database (Neo4j Aura) ---
# Example: neo4j+s://xxxxxx.databases.neo4j.io
NEO4J_URI="your_neo4j_uri"
NEO4J_USERNAME="neo4j"
NEO4J_PASSWORD="your_neo4j_password"

# --- Cache & Memory (Redis) ---
# Used for persistent LangGraph checkpointers if configured
REDIS_HOST="localhost"
REDIS_PORT=6379

# --- Observability (LangSmith) ---
# Highly recommended for production tracing
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY="your_langsmith_api_key"
LANGCHAIN_PROJECT="langguard-core-production"
